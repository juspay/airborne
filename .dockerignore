# Exclude build artifacts
target/
**/target/

# Exclude git files
.git/
.github/
.gitignore

# Exclude editor configs
.vscode/
.idea/

# Exclude Node.js modules
node_modules/
**/node_modules/

# Exclude Docusaurus build output & cache (regenerated inside the image)
airborne_docs/build/
airborne_docs/.docusaurus/

# Exclude environment files
.env*

# Exclude temporary files
**/*.rs.bk
**/*.swp

# Exclude large unnecessary files
**/*.apk
**/*.pem
**/*.p12
**/*.keystore